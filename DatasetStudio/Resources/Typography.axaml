<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="FontFamilySans">avares://DatasetStudio/Assets/Fonts#IBM Plex Sans</FontFamily>
    <FontFamily x:Key="FontFamilyMono">avares://DatasetStudio/Assets/Fonts#IBM Plex Mono</FontFamily>

    <x:Double x:Key="FontSizeHeadingLarge">24</x:Double>
    <x:Double x:Key="FontSizeHeadingMedium">18</x:Double>
    <x:Double x:Key="FontSizeBody">13</x:Double>
    <x:Double x:Key="FontSizeMeta">12</x:Double>
</ResourceDictionary>
