<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <CornerRadius x:Key="CornerRadiusSharp">2</CornerRadius>
        <Thickness x:Key="BorderThicknessThin">1</Thickness>
        <Thickness x:Key="BorderThicknessActive">2</Thickness>
        <x:Double x:Key="Space4">4</x:Double>
        <x:Double x:Key="Space8">8</x:Double>
        <x:Double x:Key="Space16">16</x:Double>
        <x:Double x:Key="Space24">24</x:Double>
    </Styles.Resources>

    <Style Selector="Application">
        <Setter Property="TextElement.Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource FontFamilySans}" />
    </Style>

    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource BrushBackground}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource BrushButtonFace}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Button:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="Button:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="Button:focus-visible:not(:disabled)">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
    </Style>

    <Style Selector="Button:disabled">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource BrushButtonDefault}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="Button.primary:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBox:focus, ComboBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="RowBackground" Value="{StaticResource BrushSurface}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="DataGridRow:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridRow:selected">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridRow:selected DataGridCell">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridCell:current, DataGridCell:focus">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="TextBlock.heading-large">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadingLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.heading-medium">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadingMedium}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.active-focus-frame">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.form-section">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.prefix-tags-frame">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.prefix-tags-frame.error">
        <Setter Property="BorderBrush" Value="{StaticResource BrushError}" />
    </Style>

    <Style Selector="Border.stage-row">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Button.project-card">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.project-card-frame">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Button.project-card:pointerover Border.project-card-frame">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="ListBox.stage-editor-list ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
</Styles>
