    <Style Selector="ListBox.stage-editor-list ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="ListBox.plain-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:pointerover Border.list-row-shell">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:selected Border.list-row-shell">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:pointerover Border.suggestion-row">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
    </Style>

    <Style Selector="ListBox.plain-list ListBoxItem:selected Border.suggestion-row">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="ListBox.plain-list.virtualized-row-list ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="ListBox.sidebar-nav-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBox.sidebar-nav-list ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="ListBox.sidebar-nav-list ListBoxItem /template/ ContentPresenter">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBox.sidebar-nav-list ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="WrapPanel.action-row">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="ItemWidth" Value="88" />
    </Style>

    <Style Selector="WrapPanel.action-row.compact">
        <Setter Property="ItemHeight" Value="32" />
    </Style>

    <Style Selector="WrapPanel.action-row.standard">
        <Setter Property="ItemHeight" Value="36" />
    </Style>

    <Style Selector="WrapPanel.action-row.compact.inset">
        <Setter Property="Margin" Value="4" />
    </Style>

    <Style Selector="WrapPanel.flow-actions">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style Selector="WrapPanel.flow-actions.compact">
        <Setter Property="ItemHeight" Value="32" />
    </Style>

    <Style Selector="WrapPanel.flow-actions.inset">
        <Setter Property="Margin" Value="4" />
    </Style>

    <Style Selector="WrapPanel.flow-actions > Button">
        <Setter Property="Margin" Value="0,0,6,6" />
