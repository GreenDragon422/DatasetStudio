<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <CornerRadius x:Key="CornerRadiusSharp">2</CornerRadius>
        <Thickness x:Key="BorderThicknessThin">1</Thickness>
        <Thickness x:Key="BorderThicknessActive">2</Thickness>
        <x:Double x:Key="Space4">4</x:Double>
        <x:Double x:Key="Space8">8</x:Double>
        <x:Double x:Key="Space16">16</x:Double>
        <x:Double x:Key="Space24">24</x:Double>
    </Styles.Resources>

    <Style Selector="Application">
        <Setter Property="TextElement.Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="TextElement.FontFamily" Value="{StaticResource FontFamilySans}" />
    </Style>

    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource BrushBackground}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource BrushButtonFace}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Button:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="Button:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="Button:focus-visible:not(:disabled)">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
    </Style>

    <Style Selector="Button:disabled">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource BrushButtonDefault}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="Button.primary:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
    </Style>

    <Style Selector="TextBox.chromeless-input">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="TextBox.short-input">
        <Setter Property="Height" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.multiline-input">
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MinHeight" Value="72" />
    </Style>

    <Style Selector="TextBox.field-input, ComboBox.field-input">
        <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style Selector="TextBox.header-control, ComboBox.header-control, Button.header-control">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.header-control-status-chip">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="MinWidth" Value="116" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.header-control-status-chip.installed">
        <Setter Property="Background" Value="{StaticResource BrushAccentSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
    </Style>

    <Style Selector="TextBlock.header-control-status-chip-text">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ComboBox:pointerover:not(:disabled)">
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="CheckBox:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="Slider">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="Foreground" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="Slider /template/ Track">
        <Setter Property="Height" Value="8" />
    </Style>

    <Style Selector="Slider /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="Slider /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="Slider /template/ Thumb">
        <Setter Property="Background" Value="{StaticResource BrushButtonFace}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
    </Style>

    <Style Selector="TextBox:focus, ComboBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="GridLinesVisibility" Value="All" />
        <Setter Property="RowBackground" Value="{StaticResource BrushSurface}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="DataGridRow:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridRow:selected">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridRow:selected DataGridCell">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="DataGridCell:current, DataGridCell:focus">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ProgressBar">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="Foreground" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="ScrollBar:pointerover">
        <Setter Property="Foreground" Value="{StaticResource BrushPrimaryDeep}" />
    </Style>

    <Style Selector="Grid.screen-root">
        <Setter Property="Margin" Value="24" />
        <Setter Property="RowSpacing" Value="16" />
    </Style>

    <Style Selector="Grid.dialog-layout">
        <Setter Property="RowSpacing" Value="16" />
        <Setter Property="MaxWidth" Value="880" />
        <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style Selector="Grid.screen-header-layout">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="Grid.content-columns">
        <Setter Property="ColumnSpacing" Value="16" />
    </Style>

    <Style Selector="Grid.info-bar-layout">
        <Setter Property="ColumnSpacing" Value="10" />
    </Style>

    <Style Selector="Grid.stage-sidebar-layout">
        <Setter Property="RowSpacing" Value="8" />
    </Style>

    <Style Selector="Grid.compact-rows">
        <Setter Property="RowSpacing" Value="8" />
    </Style>

    <Style Selector="Grid.standard-rows">
        <Setter Property="RowSpacing" Value="12" />
    </Style>

    <Style Selector="Grid.form-row">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="Grid.form-row.with-action">
    </Style>

    <Style Selector="Grid.section-header-row">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="Grid.trailing-meta-row">
        <Setter Property="ColumnSpacing" Value="12" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBlock.mono-caption">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
    </Style>

    <Style Selector="TextBlock.heading-large">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadingLarge}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.heading-medium">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeadingMedium}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.subtle-text">
        <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
    </Style>

    <Style Selector="TextBlock.subtle-text.small">
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.meta-text">
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="TextBlock.trailing-meta">
        <Setter Property="Margin" Value="12,0,0,0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.form-label">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.screen-subtitle">
        <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="TextBlock.shell-bar-text">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.error-text">
        <Setter Property="Foreground" Value="{StaticResource BrushError}" />
    </Style>

    <Style Selector="TextBlock.label-badge-text">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.label-badge-text.status">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
    </Style>

    <Style Selector="TextBlock.processing-caption">
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.active-focus-frame">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessActive}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.surface-card">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.pad-compact">
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Border.pad-8">
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.pad-12">
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.pad-16">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.pad-24">
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style Selector="Border.pad-32">
        <Setter Property="Padding" Value="32" />
    </Style>

    <Style Selector="Border.surface-card.muted-border">
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
    </Style>

    <Style Selector="Border.surface-card.wrap-tile">
        <Setter Property="Margin" Value="0,0,16,16" />
    </Style>

    <Style Selector="Border.surface-card.thumbnail-tile">
        <Setter Property="Margin" Value="0,0,12,12" />
    </Style>

    <Style Selector="Border.surface-card.list-item-card">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.surface-panel-card">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.screen-header-bar">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style Selector="Border.shell-header-bar">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style Selector="Border.modal-overlay">
        <Setter Property="Background" Value="{StaticResource BrushOverlayScrim}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style Selector="Border.modal-overlay.compact">
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.processing-overlay">
        <Setter Property="Background" Value="{StaticResource BrushOverlayScrim}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.processing-overlay.compact">
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.modal-card">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="960" />
        <Setter Property="MaxHeight" Value="780" />
    </Style>

    <Style Selector="Border.popup-card">
        <Setter Property="Width" Value="280" />
    </Style>

    <Style Selector="Border.chrome-shell">
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.chrome-shell.input">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="Border.chrome-shell.panel">
        <Setter Property="Background" Value="{StaticResource BrushSurfacePanel}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
    </Style>

    <Style Selector="Border.shortcut-bar-shell">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="14,6" />
    </Style>

    <Style Selector="Border.shortcut-keycap">
        <Setter Property="Background" Value="{StaticResource BrushButtonFace}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style Selector="TextBlock.shortcut-keycap-text">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMeta}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="TextBlock.shortcut-description">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySans}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource BrushHintText}" />
    </Style>

    <Style Selector="Border.label-badge">
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.label-badge.keys">
        <Setter Property="Background" Value="{StaticResource BrushButtonDefault}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="Border.label-badge.status">
        <Setter Property="Background" Value="{StaticResource BrushAccentSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
    </Style>


    <Style Selector="Border.status-dot">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
    </Style>

    <Style Selector="Border.thumbnail-placeholder">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="ProgressBar.processing-indicator">
        <Setter Property="Height" Value="4" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Border.warning-focus-frame">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushWarning}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.flat-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Border.list-row-shell">
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
    </Style>

    <Style Selector="Border.suggestion-row">
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
    </Style>

    <Style Selector="Border.prefix-tags-frame">
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushMuted}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
    </Style>

    <Style Selector="Border.prefix-tags-frame.error">
        <Setter Property="BorderBrush" Value="{StaticResource BrushError}" />
    </Style>

    <Style Selector="Button.card-button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Button.card-button:pointerover Border.interactive-card-frame">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="Button.card-button:pointerover, Button.card-button:pressed, Button.card-button:focus-visible">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.chromeless">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.chromeless:pointerover, Button.chromeless:pressed, Button.chromeless:focus-visible">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.inline-glyph">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.inline-glyph:pointerover, Button.inline-glyph:pressed, Button.inline-glyph:focus-visible">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.icon-button">
        <Setter Property="Background" Value="{StaticResource BrushButtonFace}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.icon-button:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimary}" />
    </Style>

    <Style Selector="Button.icon-button:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushButtonPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
    </Style>

    <Style Selector="StackPanel.inline-actions">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.edge-nav">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style Selector="Button.edge-nav.inset">
        <Setter Property="Margin" Value="8" />
    </Style>

    <Style Selector="Button.thumbnail-button">
        <Setter Property="Margin" Value="0,8,0,8" />
    </Style>

    <Style Selector="Button.thumbnail-select-chip">
        <Setter Property="Background" Value="{StaticResource BrushSurfaceInput}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSurfaceElevated}" />
        <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusSharp}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.thumbnail-select-chip:pointerover:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushSelectionSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectionBorder}" />
    </Style>

    <Style Selector="Button.thumbnail-select-chip:pressed:not(:disabled)">
        <Setter Property="Background" Value="{StaticResource BrushSelection}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDeep}" />
    </Style>

    <Style Selector="Button.thumbnail-select-chip.selected">
        <Setter Property="Background" Value="{StaticResource BrushAccentSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextStrong}" />
    </Style>

    <Style Selector="ListBox.stage-editor-list">
