<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             xmlns:vm="using:DatasetStudio.ViewModels"
             x:Class="DatasetStudio.Views.InspectorModeView"
             x:Name="InspectorRoot"
             x:DataType="vm:InspectorModeViewModel"
             x:CompileBindings="True"
             TextInput="OnScreenTextInput"
             Loaded="OnLoaded">
    <Grid RowDefinitions="Auto,*"
          Classes="screen-root">
        <Border Grid.Row="0"
                Classes="screen-header-bar">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
                <Button Content="Back"
                        Command="{Binding GoBackCommand}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Spacing="2"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}"
                               Classes="heading-medium"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ProjectName}"
                               Classes="mono-caption"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <controls:StatusDot Status="{Binding CurrentStatus}"
                                        VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentStatus}"
                               Classes="mono shell-bar-text" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="240,*,320"
              ColumnSpacing="16">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="8">
                <TextBlock Text="Workflow stages"
                           Classes="heading-medium" />
                <TextBlock Grid.Row="1"
                           Text="Choose a stage, then keep moving through the dataset with the keyboard."
                           Classes="mono screen-subtitle"
                           TextWrapping="Wrap" />
                <controls:WorkflowStageList Grid.Row="2"
                                            ItemsSource="{Binding Stages}"
                                            SelectedItem="{Binding ActiveStage, Mode=TwoWay}" />
            </Grid>

            <Border Grid.Column="1"
                    Classes="surface-card pad-16">
                <Grid RowDefinitions="*,Auto">
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                         <Viewbox Stretch="Uniform"
                                  StretchDirection="Both"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                            <Border Classes="warning-focus-frame"
                                    Padding="8">
                                <Image Source="{Binding CurrentImageSource}"
                                       Stretch="Uniform" />
                            </Border>
                        </Viewbox>

                        <Button Content="Prev"
                                Classes="edge-nav"
                                Command="{Binding NavigatePreviousCommand}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="8" />

                        <Button Content="Next"
                                Classes="edge-nav"
                                Command="{Binding NavigateNextCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="8" />
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding FileName}"
                               IsVisible="False" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Classes="surface-card pad-16">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="12">
                    <Border Classes="surface-panel-card pad-12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Prefix tags"
                                       Classes="heading-medium" />
                            <TextBlock Text="{Binding PrefixTagsText}"
                                       Classes="mono"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Spacing="6">
                        <TextBlock Text="Add tag"
                                   Classes="form-label" />
                        <TextBox x:Name="TagInputTextBox"
                                 Classes="short-input"
                                 Text="{Binding TagInputText, Mode=TwoWay}"
                                 Watermark="Type a tag and press Enter..." />
                        <Border Classes="surface-panel-card pad-8"
                                IsVisible="{Binding IsSuggestOpen}">
                            <ItemsControl ItemsSource="{Binding AutoSuggestTags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Classes="chromeless"
                                                Command="{Binding #InspectorRoot.((vm:InspectorModeViewModel)DataContext).UseSuggestionCommand}"
                                                CommandParameter="{Binding}">
                                            <Border Classes="suggestion-row">
                                                <TextBlock Text="{Binding}"
                                                           Classes="mono" />
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Border Classes="surface-panel-card pad-12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Applied tags"
                                               Classes="heading-medium" />
                                    <ItemsControl ItemsSource="{Binding AppliedTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel ItemHeight="32"
                                                           Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <controls:TagPill Tag="{Binding}"
                                                                  RemoveCommand="{Binding DataContext.RemoveTagCommand, ElementName=InspectorRoot}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border IsVisible="{Binding IsBusy}"
                                Classes="modal-overlay"
                                Padding="12"
                                VerticalAlignment="Stretch">
                            <ProgressBar IsIndeterminate="True"
                                         VerticalAlignment="Top"
                                         Height="4" />
                        </Border>
                    </Grid>

                    <Button Grid.Row="3"
                            Classes="primary"
                            Content="Commit &amp; Next"
                            Command="{Binding CommitTagCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
