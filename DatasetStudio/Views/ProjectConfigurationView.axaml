<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DatasetStudio.ViewModels"
             xmlns:models="using:DatasetStudio.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d"
              d:DesignWidth="600"
              d:DesignHeight="720"
              x:Class="DatasetStudio.Views.ProjectConfigurationView"
              x:Name="Root"
               x:DataType="vm:ProjectConfigurationViewModel"
               x:CompileBindings="True">
    <UserControl.Styles>
        <Style Selector="Border.form-section">
            <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushSurfaceElevated}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style Selector="Border.prefix-tags-frame">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
        </Style>

        <Style Selector="Border.prefix-tags-frame.error">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushError}" />
        </Style>

        <Style Selector="Border.stage-row">
            <Setter Property="Background" Value="{DynamicResource BrushSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushSurfaceElevated}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="16"
          MaxWidth="880"
          MinWidth="0">
        <StackPanel Grid.Row="0"
                    Spacing="6">
            <TextBlock Text="Project Configuration"
                       Classes="heading-large" />
            <TextBlock Text="Update the project folder, AI model, prefix tags, and workflow stages."
                       Classes="mono"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource BrushMuted}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <Border Classes="form-section"
                        Padding="16">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="12">
                        <Grid ColumnDefinitions="136,*"
                              ColumnSpacing="12">
                            <TextBlock Text="Project name"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="ProjectNameTextBox"
                                     Grid.Column="1"
                                      MinWidth="0"
                                      Text="{Binding ProjectName, Mode=TwoWay}" />
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="136,*,Auto"
                              ColumnSpacing="12">
                            <TextBlock Text="Root folder"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="RootFolderPathTextBox"
                                     Grid.Column="1"
                                      MinWidth="0"
                                      Text="{Binding RootFolderPath, Mode=TwoWay}" />
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Click="OnBrowseRootFolderClick" />
                        </Grid>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="136,*"
                              ColumnSpacing="12">
                            <TextBlock Text="AI model"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      MinWidth="0"
                                       ItemsSource="{Binding AvailableAiModels}"
                                       SelectedValue="{Binding SelectedAiModelName, Mode=TwoWay}"
                                       SelectedValueBinding="{Binding Id}"
                                      PlaceholderText="Select an AI model">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:AiModelInfo">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock Text="{Binding ModelPath}"
                                                       Classes="mono"
                                                       Foreground="{DynamicResource BrushMuted}"
                                                       FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <StackPanel Grid.Row="3"
                                    Spacing="6">
                            <TextBlock Text="Prefix tags" />
                            <Border Classes="prefix-tags-frame"
                                    Classes.error="{Binding HasPrefixTagsError}"
                                    Padding="0">
                                <TextBox Text="{Binding PrefixTagsText, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="72"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Watermark="lora_style, masterpiece, best quality" />
                            </Border>
                            <TextBlock Text="{Binding PrefixTagsError}"
                                       IsVisible="{Binding HasPrefixTagsError}"
                                       Foreground="{DynamicResource BrushError}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="form-section"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <TextBlock Text="Workflow stages"
                                       Classes="heading-medium" />
                            <Button Grid.Column="1"
                                    Content="Add Stage"
                                    Command="{Binding AddStageCommand}" />
                        </Grid>

                        <ListBox ItemsSource="{Binding Stages}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectConfigurationStageViewModel">
                                    <Border Classes="stage-row"
                                            Margin="0,0,0,8"
                                     Padding="12"
                                     DragDrop.AllowDrop="True"
                                     AttachedToVisualTree="OnStageRowAttachedToVisualTree"
                                     DetachedFromVisualTree="OnStageRowDetachedFromVisualTree">
                                        <Grid RowDefinitions="Auto,Auto"
                                              ColumnDefinitions="Auto,Auto,*,*"
                                              RowSpacing="8"
                                              ColumnSpacing="10">
                                            <TextBlock Text="⋮⋮"
                                                        Width="24"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource BrushMuted}"
                                                        PointerPressed="OnStageDragHandlePointerPressed"
                                                        Cursor="SizeAll"
                                                        />

                                            <TextBlock Text="{Binding OrderDisplay}"
                                                       Classes="mono"
                                                       VerticalAlignment="Center" />

                                            <TextBox Grid.Column="2"
                                                     MinWidth="0"
                                                     Text="{Binding FolderName, Mode=TwoWay}"
                                                     Watermark="01_Inbox" />

                                            <TextBox Grid.Column="3"
                                                     MinWidth="0"
                                                     Text="{Binding DisplayName, Mode=TwoWay}"
                                                     Watermark="Inbox" />

                                            <WrapPanel Grid.Row="1"
                                                       Grid.ColumnSpan="4"
                                                       HorizontalAlignment="Right"
                                                       Orientation="Horizontal"
                                                       ItemHeight="36"
                                                       ItemWidth="88">
                                                <Button Content="Up"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).MoveStageUpCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Down"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).MoveStageDownCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Delete"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).RemoveStageCommand}"
                                                        CommandParameter="{Binding}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Classes="primary"
                    Content="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}" />
        </StackPanel>
    </Grid>
</UserControl>
