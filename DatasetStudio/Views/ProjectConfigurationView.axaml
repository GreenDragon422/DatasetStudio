<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DatasetStudio.ViewModels"
             xmlns:models="using:DatasetStudio.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d"
              d:DesignWidth="600"
              d:DesignHeight="720"
              x:Class="DatasetStudio.Views.ProjectConfigurationView"
              x:Name="Root"
               x:DataType="vm:ProjectConfigurationViewModel"
               x:CompileBindings="True">
    <Grid RowDefinitions="Auto,*,Auto"
          Classes="dialog-layout">
        <StackPanel Grid.Row="0"
                    Classes="section-stack tight">
            <TextBlock Text="Project Configuration"
                       Classes="heading-large" />
            <TextBlock Text="Update the project folder, AI model, prefix tags, and workflow stages."
                       Classes="mono screen-subtitle"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Classes="section-stack wide">
                <Border Classes="surface-card pad-16">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          Classes="standard-rows">
                        <Grid ColumnDefinitions="136,*"
                              Classes="form-row">
                            <TextBlock Text="Project name"
                                       Classes="form-label" />
                            <TextBox x:Name="ProjectNameTextBox"
                                      Grid.Column="1"
                                      Classes="field-input"
                                       Text="{Binding ProjectName, Mode=TwoWay}" />
                        </Grid>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="136,*,Auto"
                              Classes="form-row with-action">
                            <TextBlock Text="Root folder"
                                       Classes="form-label" />
                            <TextBox x:Name="RootFolderPathTextBox"
                                      Grid.Column="1"
                                      Classes="field-input"
                                       Text="{Binding RootFolderPath, Mode=TwoWay}" />
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Click="OnBrowseRootFolderClick" />
                        </Grid>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="136,*"
                              Classes="form-row">
                            <TextBlock Text="AI model"
                                       Classes="form-label" />
                            <StackPanel Grid.Column="1"
                                        Classes="model-selection-stack">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <ComboBox Classes="field-input"
                                               ItemsSource="{Binding AvailableAiModels}"
                                               SelectedValue="{Binding SelectedAiModelName, Mode=TwoWay}"
                                               SelectedValueBinding="{Binding Id}"
                                               PlaceholderText="Select an AI model">
                                        <ComboBox.SelectionBoxItemTemplate>
                                            <DataTemplate x:DataType="models:AiModelInfo">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrushTextStrong}" />
                                            </DataTemplate>
                                        </ComboBox.SelectionBoxItemTemplate>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:AiModelInfo">
                                                <StackPanel Classes="screen-title-stack">
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Classes="mono-caption" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <Button Grid.Column="1"
                                            Content="{Binding DownloadSelectedAiModelButtonText}"
                                            Command="{Binding DownloadSelectedAiModelCommand}"
                                            IsEnabled="{Binding CanDownloadSelectedAiModel}" />
                                </Grid>

                                <TextBlock Text="{Binding SelectedAiModelStatusText}"
                                           Classes="mono-caption"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="3"
                                    Classes="section-stack tight">
                            <TextBlock Text="Prefix tags"
                                       Classes="form-label" />
                            <Border Classes="prefix-tags-frame"
                                    Classes.error="{Binding HasPrefixTagsError}"
                                    Padding="0">
                                <TextBox Text="{Binding PrefixTagsText, Mode=TwoWay}"
                                         Classes="chromeless-input multiline-input"
                                         Watermark="lora_style, masterpiece, best quality" />
                            </Border>
                            <TextBlock Text="{Binding PrefixTagsError}"
                                       Classes="error-text"
                                       IsVisible="{Binding HasPrefixTagsError}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="surface-card pad-16">
                    <StackPanel Classes="section-stack wide">
                        <Grid ColumnDefinitions="*,Auto"
                              Classes="section-header-row">
                            <TextBlock Text="Workflow stages"
                                       Classes="heading-medium" />
                            <Button Grid.Column="1"
                                    Content="Add Stage"
                                    Command="{Binding AddStageCommand}" />
                        </Grid>

                        <ListBox ItemsSource="{Binding Stages}"
                                 Classes="stage-editor-list">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProjectConfigurationStageViewModel">
                                    <Border Classes="surface-card pad-12 list-item-card"
                                            DragDrop.AllowDrop="True"
                                            AttachedToVisualTree="OnStageRowAttachedToVisualTree"
                                            DetachedFromVisualTree="OnStageRowDetachedFromVisualTree">
                                        <Grid ColumnDefinitions="Auto,Auto,*,*,Auto"
                                              Classes="compact-rows"
                                              ColumnSpacing="10">
                                            <TextBlock Text="⋮⋮"
                                                        Width="24"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Classes="subtle-text"
                                                        PointerPressed="OnStageDragHandlePointerPressed"
                                                        Cursor="SizeAll"
                                                        />

                                            <TextBlock Text="{Binding OrderDisplay}"
                                                       Classes="mono"
                                                       VerticalAlignment="Center" />

                                            <TextBox Grid.Column="2"
                                                     Classes="field-input"
                                                     Text="{Binding FolderName, Mode=TwoWay}"
                                                     Watermark="01_Inbox" />

                                            <TextBox Grid.Column="3"
                                                     Classes="field-input"
                                                     Text="{Binding DisplayName, Mode=TwoWay}"
                                                     Watermark="Inbox" />

                                            <StackPanel Grid.Column="4"
                                                        Classes="inline-actions">
                                                <Button Classes="icon-button"
                                                        Content="↑"
                                                        ToolTip.Tip="Move stage up"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).MoveStageUpCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Classes="icon-button"
                                                        Content="↓"
                                                        ToolTip.Tip="Move stage down"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).MoveStageDownCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Classes="icon-button"
                                                        Content="✕"
                                                        ToolTip.Tip="Delete stage"
                                                        Command="{Binding #Root.((vm:ProjectConfigurationViewModel)DataContext).RemoveStageCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Classes="dialog-actions">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Classes="primary"
                    Content="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}" />
        </StackPanel>
    </Grid>
</UserControl>
