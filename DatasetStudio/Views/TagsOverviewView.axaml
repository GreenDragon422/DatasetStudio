<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DatasetStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="DatasetStudio.Views.TagsOverviewView"
             x:DataType="vm:TagsOverviewViewModel"
             x:CompileBindings="True"
             d:DesignWidth="1440"
             d:DesignHeight="860">
    <Grid RowDefinitions="64,*"
          Classes="screen-root">
        <Border Grid.Row="0"
                Classes="screen-header-bar">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  Classes="screen-header-layout">
                <StackPanel Classes="screen-title-stack">
                    <TextBlock Text="Tags Overview"
                               Classes="heading-medium" />
                    <TextBlock Text="Review aliases, frequencies, and tag cleanup actions across the active project."
                               Classes="mono screen-subtitle"
                               TextWrapping="Wrap" />
                </StackPanel>
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="1"
                         Classes="header-control"
                         Width="320"
                         Watermark="Search tags or aliases..."
                         Text="{Binding SearchText, Mode=TwoWay}" />
                <Button Grid.Column="2"
                        Classes="primary header-control"
                        Content="New Tag"
                        Command="{Binding NewTagCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="240,*"
              Classes="content-columns">
            <Border Classes="surface-card pad-12">
                <StackPanel Classes="section-stack">
                    <TextBlock Text="Categories"
                               Classes="heading-medium" />
                    <ListBox ItemsSource="{Binding Categories}"
                             Classes="sidebar-nav-list"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Classes="surface-card pad-8">
                <DataGrid ItemsSource="{Binding FilteredEntries}"
                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Tag Name"
                                                SortMemberPath="CanonicalName"
                                                Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:TagsOverviewRowViewModel">
                                    <Border Classes="flat-row"
                                            DoubleTapped="OnEntryDoubleTapped">
                                        <Grid>
                                            <TextBlock Text="{Binding CanonicalName}"
                                                       Classes="mono"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding !IsEditing}" />
                                            <TextBox Text="{Binding CanonicalName, Mode=TwoWay}"
                                                     IsVisible="{Binding IsEditing}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Alias"
                                                Width="3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:TagsOverviewRowViewModel">
                                    <Border Classes="flat-row">
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayAliases}"
                                                       Classes="mono"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding !IsEditing}" />
                                            <TextBox Text="{Binding EditableAliasesText, Mode=TwoWay}"
                                                     Watermark="comma, separated, aliases"
                                                     IsVisible="{Binding IsEditing}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Global Frequency"
                                            Binding="{Binding GlobalFrequency}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header="Actions"
                                                Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:TagsOverviewRowViewModel">
                                    <WrapPanel Classes="flow-actions compact inset">
                                        <Button Content="Edit"
                                                IsVisible="{Binding !IsEditing}"
                                                Click="OnEditClick" />
                                        <Button Content="Save"
                                                IsVisible="{Binding IsEditing}"
                                                Click="OnSaveClick" />
                                        <Button Content="Cancel"
                                                IsVisible="{Binding IsEditing}"
                                                Click="OnCancelClick" />
                                        <Button Content="Merge"
                                                Click="OnMergeClick" />
                                        <Button Content="Delete"
                                                Click="OnDeleteClick" />
                                        <Button Content="Delete + Files"
                                                Click="OnDeleteWithFilesClick" />
                                    </WrapPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
