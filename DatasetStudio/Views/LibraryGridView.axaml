<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             xmlns:models="using:DatasetStudio.Models"
             xmlns:vm="using:DatasetStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="DatasetStudio.Views.LibraryGridView"
             x:Name="Root"
             x:DataType="vm:LibraryGridViewModel"
             x:CompileBindings="True"
             d:DesignWidth="1440"
             d:DesignHeight="860">
    <Grid RowDefinitions="64,*"
          Classes="screen-root">
        <Border Grid.Row="0"
                Classes="screen-header-bar">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  Classes="screen-header-layout">
                <StackPanel Classes="screen-title-stack">
                    <TextBlock Text="{Binding ProjectName}"
                               Classes="heading-medium" />
                    <TextBlock Text="Review Workspace · choose a workflow stage, review staged images, filter by tags, and prepare batch tag edits."
                               Classes="mono screen-subtitle"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          Width="220"
                          ItemsSource="{Binding AiModels}"
                          SelectedItem="{Binding SelectedAiModel, Mode=TwoWay}"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:AiModelInfo">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox x:Name="FilterTextBox"
                         Grid.Column="2"
                         Width="280"
                         Watermark="Quick filter tags or filenames..."
                         Text="{Binding FilterText, Mode=TwoWay}"
                         VerticalAlignment="Center" />
            </Grid>
        </Border>

        <controls:BatchPopup x:Name="BatchAddPopup"
                             Grid.Row="0"
                             IsOpen="{Binding IsBatchAddOpen, Mode=TwoWay}"
                             Mode="Add"
                             PlacementTarget="{Binding #FilterTextBox}"
                             Placement="Bottom"
                             HorizontalOffset="0"
                             VerticalOffset="8"
                             QueryText="{Binding BatchAddQueryText, Mode=TwoWay}"
                             Suggestions="{Binding BatchAddSuggestions}"
                             SelectedSuggestion="{Binding SelectedBatchAddSuggestion, Mode=TwoWay}" />

        <controls:BatchPopup x:Name="BatchRemovePopup"
                             Grid.Row="0"
                             IsOpen="{Binding IsBatchRemoveOpen, Mode=TwoWay}"
                             Mode="Remove"
                             PlacementTarget="{Binding #FilterTextBox}"
                             Placement="Bottom"
                             HorizontalOffset="0"
                             VerticalOffset="8"
                             QueryText="{Binding BatchRemoveQueryText, Mode=TwoWay}"
                             Suggestions="{Binding BatchRemoveSuggestions}"
                             SelectedSuggestion="{Binding SelectedBatchRemoveSuggestion, Mode=TwoWay}" />

        <Grid Grid.Row="1"
              ColumnDefinitions="240,*"
              Classes="content-columns">
            <Grid RowDefinitions="Auto,Auto,*"
                  Classes="stage-sidebar-layout">
                <TextBlock Text="Workflow stages"
                           Classes="heading-medium" />
                <TextBlock Grid.Row="1"
                           Text="Pick the current folder/stage to review or retag."
                           Classes="mono screen-subtitle"
                           TextWrapping="Wrap" />
                <controls:WorkflowStageList Grid.Row="2"
                                            ItemsSource="{Binding Stages}"
                                            SelectedItem="{Binding ActiveStage, Mode=TwoWay}" />
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="*,Auto"
                  Classes="standard-rows">
                <Border Classes="surface-card pad-16">
                    <Grid>
                        <TextBlock Text="Folder is empty. Drag images here to stage."
                                   Classes="heading-medium"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !HasImages}" />

                        <ScrollViewer x:Name="ImagesScrollViewer"
                                      IsVisible="{Binding HasImages}"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Images}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LibraryGridImageViewModel">
                                        <Border Width="{Binding #Root.((vm:LibraryGridViewModel)DataContext).ZoomValue}"
                                                Classes="surface-card wrap-tile pad-8">
                                            <Grid RowDefinitions="Auto,*,Auto">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="8">
                                                    <CheckBox Command="{Binding #Root.((vm:LibraryGridViewModel)DataContext).ToggleSelectionCommand}"
                                                              CommandParameter="{Binding}"
                                                              IsChecked="{Binding IsSelected, Mode=OneWay}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding FileName}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </Grid>

                                                <Button Grid.Row="1"
                                                        Classes="chromeless"
                                                        Margin="0,8,0,8"
                                                        Command="{Binding #Root.((vm:LibraryGridViewModel)DataContext).FocusImageCommand}"
                                                        CommandParameter="{Binding}"
                                                        DoubleTapped="OnThumbnailDoubleTapped">
                                                    <Grid Width="{Binding #Root.((vm:LibraryGridViewModel)DataContext).ZoomValue}"
                                                          Height="{Binding #Root.((vm:LibraryGridViewModel)DataContext).ZoomValue}">
                                                        <Border Classes="thumbnail-placeholder" />
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding HasThumbnail}" />
                                                        <TextBlock Text="{Binding FileName}"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12"
                                                                   IsVisible="{Binding !HasThumbnail}" />
                                                        <Border Classes="active-focus-frame"
                                                                IsVisible="{Binding IsFocused}" />
                                                        <controls:StatusDot HorizontalAlignment="Right"
                                                                            VerticalAlignment="Bottom"
                                                                            Margin="0,0,6,6"
                                                                            Status="{Binding Status}" />
                                                    </Grid>
                                                </Button>

                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding TagsPreview}"
                                                           Classes="mono meta-text"
                                                           MaxWidth="{Binding #Root.((vm:LibraryGridViewModel)DataContext).ZoomValue}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1"
                            Classes="toolbar-row">
                    <TextBlock Text="Zoom"
                               Classes="mono"
                               VerticalAlignment="Center" />
                    <Slider Width="180"
                            Minimum="100"
                            Maximum="400"
                            Value="{Binding ZoomValue, Mode=TwoWay}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
