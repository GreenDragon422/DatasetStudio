<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DatasetStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1440"
             d:DesignHeight="860"
             x:Class="DatasetStudio.Views.ProjectsHubView"
             x:DataType="vm:ProjectsHubViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="64,*"
          Classes="screen-root">
        <Border Grid.Row="0"
                Classes="screen-header-bar">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  Classes="screen-header-layout">
                <TextBlock Text="Master root"
                           Classes="heading-medium" />

                <TextBox x:Name="MasterRootPathTextBox"
                         Grid.Column="1"
                         Classes="header-control"
                         Watermark="Choose a master root folder, or paste a path and press Enter..."
                         Text="{Binding MasterRootPath, Mode=TwoWay}" />

                <Button Grid.Column="2"
                        Classes="header-control"
                        Content="Browse"
                        Click="OnBrowseMasterRootClick" />

                <Button Grid.Column="3"
                        Classes="primary header-control"
                        Content="New Project"
                        Command="{Binding NewProjectCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border IsVisible="{Binding IsEmptyStateVisible}"
                    Classes="surface-card muted-border pad-32">
                <StackPanel Classes="empty-state-stack">
                    <TextBlock Text="No datasets found. Create your first project or point to a master folder."
                               Classes="heading-medium"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="520" />
                    <TextBlock Text="Choose a master root and the hub will scan it automatically. Press Enter after typing a path."
                               Classes="mono"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="520" />
                </StackPanel>
            </Border>

            <ScrollViewer IsVisible="{Binding HasProjects}"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="320"
                                       ItemHeight="180"
                                       Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProjectsHubProjectCardViewModel">
                            <Button Classes="card-button"
                                    Command="{Binding OpenCommand}">
                                <Border Classes="surface-card interactive-card-frame pad-16 wrap-tile"
                                        Width="300"
                                        Height="164">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                          RowSpacing="6">
                                        <TextBlock Text="{Binding Name}"
                                                   Classes="heading-medium"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding RootFolderPath}"
                                                   Classes="mono subtle-text"
                                                   TextTrimming="CharacterEllipsis" />

                                        <StackPanel Grid.Row="2"
                                                    Classes="inline-metrics">
                                            <TextBlock Text="{Binding ImageCountText}"
                                                       Classes="mono" />
                                            <TextBlock Text="{Binding TaggedPercentageText}"
                                                       Classes="mono" />
                                        </StackPanel>

                                        <ProgressBar Grid.Row="3"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding TaggedPercentage}"
                                                     Height="10" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
