<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             xmlns:conv="using:DatasetStudio.Converters"
             x:Class="DatasetStudio.Controls.StatusDot"
             x:DataType="controls:StatusDot">
  <UserControl.Resources>
    <conv:TagStatusToBrushConverter x:Key="TagStatusToBrushConverter" />
  </UserControl.Resources>

  <Border Width="12"
          Height="12"
          CornerRadius="6"
          Background="{Binding Status, Converter={StaticResource TagStatusToBrushConverter}}"
          BorderBrush="{DynamicResource BrushSurfaceElevated}"
          BorderThickness="1" />
</UserControl>
