<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             xmlns:conv="using:DatasetStudio.Converters"
             x:Class="DatasetStudio.Controls.StatusDot"
             x:Name="Root"
             x:DataType="controls:StatusDot">
  <UserControl.Resources>
    <conv:TagStatusToBrushConverter x:Key="TagStatusToBrushConverter" />
  </UserControl.Resources>

  <Border Classes="status-dot"
          Width="12"
          Height="12"
          Background="{Binding #Root.Status, Converter={StaticResource TagStatusToBrushConverter}}"
          />
</UserControl>
