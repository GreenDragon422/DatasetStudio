<Popup xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="using:DatasetStudio.Controls"
       xmlns:vm="using:DatasetStudio.ViewModels"
       x:Class="DatasetStudio.Controls.BatchPopup"
       x:Name="Root"
       x:DataType="controls:BatchPopup">
  <Border Classes="surface-panel-card pad-12 popup-card">
    <Grid RowDefinitions="Auto,Auto,*"
          Classes="compact-rows">
      <TextBlock Text="{Binding #Root.Mode}"
                 Classes="heading-medium" />

      <TextBox x:Name="QueryTextBox"
               Grid.Row="1"
               Text="{Binding #Root.QueryText, Mode=TwoWay}"
               Watermark="Type to filter tags" />

      <ListBox Grid.Row="2"
               ItemsSource="{Binding #Root.Suggestions}"
               SelectedItem="{Binding #Root.SelectedSuggestion, Mode=TwoWay}"
               Classes="plain-list"
               MaxHeight="220">
        <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:BatchTagSuggestionViewModel">
          <Border Classes="suggestion-row">
              <Grid ColumnDefinitions="*,Auto"
                    Classes="trailing-meta-row">
                <TextBlock Text="{Binding Tag}"
                           Classes="mono" />
                 <TextBlock Grid.Column="1"
                            Text="{Binding Frequency}"
                            Classes="mono-caption trailing-meta"
                            IsVisible="{Binding HasFrequency}"
                            />
               </Grid>
             </Border>
           </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Border>
</Popup>
