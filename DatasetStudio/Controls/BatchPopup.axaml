<Popup xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="using:DatasetStudio.Controls"
       x:Class="DatasetStudio.Controls.BatchPopup"
       x:DataType="controls:BatchPopup">
  <Border Background="{DynamicResource BrushSurfacePanel}"
          BorderBrush="{DynamicResource BrushSurfaceElevated}"
          BorderThickness="1"
          CornerRadius="2"
          Padding="12"
          Width="280">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
      <TextBlock Text="{Binding Mode}"
                 Classes="heading-medium"
                 Foreground="{DynamicResource BrushTextStrong}" />

      <TextBox Grid.Row="1"
               Text="{Binding QueryText, Mode=TwoWay}"
               Watermark="Type to filter tags" />

      <ListBox Grid.Row="2"
               ItemsSource="{Binding Suggestions}"
               SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
               Background="Transparent"
               BorderThickness="0"
               MaxHeight="220">
        <ListBox.ItemTemplate>
        <DataTemplate x:CompileBindings="False">
          <Border Padding="8,4"
                  Margin="0,2"
                  CornerRadius="2"
                  Background="{DynamicResource BrushSurfaceInput}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding}"
                           Classes="mono" />
                 <TextBlock Grid.Column="1"
                            Text="{Binding Frequency}"
                            Classes="mono"
                            Margin="12,0,0,0"
                            Foreground="{DynamicResource BrushMuted}" />
               </Grid>
             </Border>
           </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Border>
</Popup>
