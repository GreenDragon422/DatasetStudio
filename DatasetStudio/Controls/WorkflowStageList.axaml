<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             x:Class="DatasetStudio.Controls.WorkflowStageList"
             x:DataType="controls:WorkflowStageList">
  <Border Background="{DynamicResource BrushSurface}"
          BorderBrush="{DynamicResource BrushSurfaceElevated}"
          BorderThickness="1"
          CornerRadius="2">
    <ListBox ItemsSource="{Binding ItemsSource}"
             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0">
      <ListBox.ItemTemplate>
        <DataTemplate x:CompileBindings="False">
          <Border Margin="4,2"
                  Padding="8,6"
                  CornerRadius="2"
                  Background="Transparent">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding DisplayName}"
                           Classes="heading-medium" />
                <TextBlock Text="{Binding FolderName}"
                           Classes="mono"
                           Foreground="{DynamicResource BrushMuted}"
                           FontSize="11" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding ImageCount}"
                         Classes="mono"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right"
                         Margin="12,0,0,0" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Border>
</UserControl>
