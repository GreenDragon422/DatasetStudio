<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             x:Class="DatasetStudio.Controls.WorkflowStageList"
             x:Name="Root"
             x:DataType="controls:WorkflowStageList">
  <Border Classes="surface-card">
    <ListBox ItemsSource="{Binding #Root.ItemsSource}"
             SelectedItem="{Binding #Root.SelectedItem, Mode=TwoWay}"
             Classes="plain-list">
      <ListBox.ItemTemplate>
        <DataTemplate x:CompileBindings="False">
          <Border Classes="list-row-shell">
            <Grid ColumnDefinitions="*,Auto"
                  Classes="trailing-meta-row">
              <StackPanel Classes="screen-title-stack">
                <TextBlock Text="{Binding DisplayName}"
                           Classes="heading-medium" />
                <TextBlock Text="{Binding FolderName}"
                           Classes="mono-caption" />
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding ImageCount}"
                         Classes="mono trailing-meta" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Border>
</UserControl>
