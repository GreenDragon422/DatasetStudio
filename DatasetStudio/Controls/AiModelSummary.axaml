<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             x:Class="DatasetStudio.Controls.AiModelSummary"
             x:Name="Root"
             x:DataType="controls:AiModelSummary">
    <WrapPanel Classes="ai-model-summary">
        <TextBlock Text="{Binding #Root.ModelName}"
                   Classes="ai-model-summary-name"
                   VerticalAlignment="Center" />

        <Border Classes="ai-model-summary-chip"
                Classes.installed="{Binding #Root.IsInstalled}"
                Classes.busy="{Binding #Root.IsBusy}"
                Classes.attention="{Binding #Root.IsAttention}"
                IsVisible="{Binding #Root.HasStatus}">
            <TextBlock Text="{Binding #Root.StatusText}"
                       Classes="ai-model-summary-chip-text" />
        </Border>
    </WrapPanel>
</UserControl>
