<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             x:Class="DatasetStudio.Controls.TagPill"
             x:DataType="controls:TagPill">
  <Border Background="{DynamicResource BrushSurface}"
          BorderBrush="{DynamicResource BrushSurfaceElevated}"
          BorderThickness="1"
          CornerRadius="2"
          Padding="8,4">
    <Grid ColumnDefinitions="Auto,Auto" VerticalAlignment="Center">
      <TextBlock Text="{Binding Tag}"
                 Classes="mono"
                 VerticalAlignment="Center" />
      <Button Grid.Column="1"
              Command="{Binding RemoveCommand}"
              CommandParameter="{Binding Tag}"
              Background="Transparent"
              BorderThickness="0"
              Margin="8,0,0,0"
              Padding="0"
              VerticalAlignment="Center">
        <TextBlock Text="x"
                   Classes="mono"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource BrushMuted}" />
      </Button>
    </Grid>
  </Border>
</UserControl>
