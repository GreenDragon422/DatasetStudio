<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DatasetStudio.Controls"
             x:Class="DatasetStudio.Controls.HintBar"
             x:Name="Root"
             x:DataType="controls:HintBar">
  <Border Classes="chrome-shell input">
    <Grid ColumnDefinitions="Auto,*"
          Classes="info-bar-layout">
      <Border Classes="label-badge keys">
        <TextBlock Text="KEYS"
                   Classes="mono label-badge-text" />
      </Border>
      <TextBlock Grid.Column="1"
                 Text="{Binding #Root.Text}"
                 Classes="shell-bar-text"
                 TextTrimming="CharacterEllipsis" />
    </Grid>
  </Border>
</UserControl>
